# Binance API credentials (for testnet or live mode)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Optional: master password for encrypted credential store
# Set this in your shell or secrets manager — never commit it
# MASTER_PASSWORD=your_master_password_here

# Optional: Discord webhook for trade notifications
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Optional: Telegram bot notifications
# TELEGRAM_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
